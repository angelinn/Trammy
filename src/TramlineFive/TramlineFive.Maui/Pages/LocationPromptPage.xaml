<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TramlineFive.Maui.Pages.LocationPromptPage"
             xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             Shell.FlyoutBehavior="Disabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
            <RowDefinition Height="100" />
            <RowDefinition Height="120" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <skia:SKLottieView Grid.Row="1" Source="map-city-lottie.json" RepeatCount="-1" HeightRequest="120" WidthRequest="120" />
        <Label Grid.Row="2" FontSize="21" HorizontalTextAlignment="Center" Margin="15,10,15,10" Text="Позволи на Trammy да използва местоположението ти." />
        
        <Label Grid.Row="3" HorizontalTextAlignment="Center" FontSize="15">
            <Label.Text>
Приложението не събира никакви данни от устройството.
Използва се единствено местоположението, за да покаже точна информация за спирките наоколо. 🗺️
                
Местоположението не се съхранява или споделя.
            </Label.Text>
        </Label> 

        <Button Grid.Row="4" VerticalOptions="Start" Clicked="LocationPromptClicked" Text="Позволи" Background="DodgerBlue" TextColor="White" Margin="30,20,30,0"/>
        <Switch />
    </Grid>
</ContentPage>
